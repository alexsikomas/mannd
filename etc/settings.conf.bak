[storage]
# Config path not changeable as it is required to find this file
state = "${HOME}/.local/state"

[debug]
max_log_level=info

[theme]
selected = dark

[theme.light]
background = #fbf1c7
foreground = #3c3836
muted = #a89984
error = #9d0006
warning = #b57614
success = #79740e
info = #076678
primary = #458588
secondary = #689d6a
tertiary = #8f3f71
accent = #d79921

[theme.dark]
background = #282828
foreground = #ebdbb2
muted = #928374
error = #cc241d
warning = #d79921
success = #98971a
info = #458588
primary = #83a598
secondary = #8ec07c
tertiary = #d3869b
accent = #fabd2f

[keybinds]
"<Up>" = up
"<Down>" = down
"<Left>" = left
"<Right>" = right
"<CR>" = enter
"<Esc>" = esc
"<BS>" = backspace
